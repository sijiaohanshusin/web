# 复制为 /opt/heuesta/.env 并修改（此文件不入库，见 .gitignore）
DJANGO_SECRET_KEY=change-me-to-a-long-random-string
DJANGO_ALLOWED_HOSTS=heuesta.cn,www.heuesta.cn
POSTGRES_DB=heuesta
POSTGRES_USER=heuesta
POSTGRES_PASSWORD=change-me-too
# 论坛账号互通签名密钥（与 /opt/heuesta/forum.env 中的 NODEBB_JWT_SECRET 保持一致）
NODEBB_JWT_SECRET=change-me-shared-with-forum

