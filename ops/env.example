# 复制为 /opt/heuesta/.env 并修改（此文件不入库，见 .gitignore）
DJANGO_SECRET_KEY=change-me-to-a-long-random-string
DJANGO_ALLOWED_HOSTS=heuesta.cn,www.heuesta.cn
POSTGRES_DB=heuesta
POSTGRES_USER=heuesta
POSTGRES_PASSWORD=change-me-too
# 论坛账号互通签名密钥（与 /opt/heuesta/forum.env 中的 NODEBB_JWT_SECRET 保持一致）
NODEBB_JWT_SECRET=change-me-shared-with-forum

# 邮件（验证码/找回密码/审核通知）。以 QQ 邮箱为例：开启 SMTP 后拿授权码
# 不配置 EMAIL_HOST_USER 时，验证码会打印到 docker 日志（仅应急）
EMAIL_HOST=smtp.qq.com
EMAIL_PORT=465
EMAIL_USE_SSL=1
EMAIL_HOST_USER=your-qq@qq.com
EMAIL_HOST_PASSWORD=your-smtp-authorization-code

# ---- 另建 /opt/heuesta/forum.env（论坛专用，同样不入库）----
# NODEBB_DB_PASSWORD=nodebb-db-password
# NODEBB_JWT_SECRET=与上面一致
# NODEBB_ADMIN_PASSWORD=论坛管理员初始密码
